  "keyFeatures": [
    "In-process vector database with no server required",
    "Multiple index algorithms (HNSW, IVF, Flat) for optimal performance",
    "Dense and sparse vector support with multi-vector queries",
    "Hybrid search combining semantic similarity with structured filters",
    "Built-in embedding functions for OpenAI, Qwen, and SentenceTransformers",
    "Advanced re-ranking capabilities (RRF, Weighted, Model-based)",
    "Production-grade performance powered by Alibaba's Proxima engine",
    "Quantization support for memory-efficient storage"
  ],
  "publicApiSurface": [
    "zvec.init() - Initialize the engine with configuration",
    "zvec.create_and_open() - Create and open a new collection",
    "zvec.open() - Open an existing collection",
    "Collection.insert() - Insert documents with vectors",
    "Collection.query() - Query by vector similarity",
    "Collection.update() - Update documents",
    "Collection.delete() - Delete documents",
    "Collection.create_index() - Build indexes on vector columns",
    "VectorQuery - Define vector similarity queries",
    "CollectionSchema - Define collection structure",
    "VectorSchema - Define vector column schemas",
    "HnswIndexParam - Configure HNSW index",
    "IVFIndexParam - Configure IVF index",
    "DenseEmbeddingFunction - Base class for dense embeddings",
    "SparseEmbeddingFunction - Base class for sparse embeddings",
    "ReRanker - Base class for re-ranking implementations"
  ]
